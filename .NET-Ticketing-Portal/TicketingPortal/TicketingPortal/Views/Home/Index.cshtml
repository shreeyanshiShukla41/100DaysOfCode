@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-4">
    <div class="p-5 mb-4 bg-light rounded-3 border">
        <div class="container-fluid py-5">
            <h1 class="display-5 fw-bold text-dark">🎉 Ticketing Portal Dashboard is Live</h1>
            <p class="col-md-8 fs-4 text-secondary">
                User Information Area
            </p>
            <hr class="my-4">
            <p>Aapki security details niche hain:</p>
            <div class="card p-3 bg-white" style="max-width: 400px;">
                <p class="mb-1"><strong>User Name:</strong> @User.Identity.Name</p>
                <p class="mb-0"><strong>Role Assigned:</strong> @User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</p>
            </div>
        </div>
    </div>
</div>