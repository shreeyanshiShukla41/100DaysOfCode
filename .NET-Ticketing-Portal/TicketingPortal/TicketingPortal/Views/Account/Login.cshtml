@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in - MyTicketingPortal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/Login.css" />
</head>
<body>

    <div class="container-fluid h-100 p-0">
        <div class="row h-100 g-0">

            <div class="col-md-5 brand-side d-none d-md-flex">
                <div>
                    <h4 class="fw-semibold d-flex align-items-center gap-2">
                        <span class="feature-icon"><i class="bi bi-layers-half"></i></span> MyTicketingPortal
                    </h4>

                    <h1 class="fw-bold mt-5 display-5" style="line-height: 1.2;">Resolve faster,<br>together.</h1>
                    <p class="text-white-50 mt-3 fs-5">Your team's unified workspace for tracking, prioritising, and closing tickets at speed.</p>

                    <div class="mt-5 d-flex flex-column gap-4">
                        <div class="d-flex gap-3">
                            <span class="feature-icon flex-shrink-0"><i class="bi bi-lightning-charge"></i></span>
                            <div>
                                <h6 class="mb-1 fw-semibold">Real-time updates</h6>
                                <small class="text-white-50">Live status changes and notifications across your team.</small>
                            </div>
                        </div>
                        <div class="d-flex gap-3">
                            <span class="feature-icon flex-shrink-0"><i class="bi bi-bar-chart-line"></i></span>
                            <div>
                                <h6 class="mb-1 fw-semibold">Insightful reports</h6>
                                <small class="text-white-50">SLA tracking, resolution trends, and team performance.</small>
                            </div>
                        </div>
                        <div class="d-flex gap-3">
                            <span class="feature-icon flex-shrink-0"><i class="bi bi-shield-check"></i></span>
                            <div>
                                <h6 class="mb-1 fw-semibold">Enterprise security</h6>
                                <small class="text-white-50">SSO, role-based access, and audit logs built in.</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="text-white-50 small">
                    &copy; 2026 MyTicketingPortal Inc. All rights reserved.
                </div>
            </div>

            <div class="col-md-7 form-side">
                <div class="login-box">
                    <h2 class="fw-semibold mb-1">Welcome back</h2>
                    <p class="text-secondary mb-4">Sign in to your TicketingPortal account</p>

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger py-2 small" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.ErrorMessage
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label text-secondary small" for="workEmail">Work email</label>
                            <input type="email"
                                   id="workEmail"
                                   name="email"
                                   autocomplete="username"
                                   class="form-control form-control-custom"
                                   placeholder="rahul@@acmecorp.in"
                                   @* /* Context se cookie nikaal kar value mein set kar di * / *@
                                   value="@Context.Request.Cookies["RememberedEmail"]"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-secondary small" for="userPassword">Password</label>
                            <div class="position-relative">
                                <input type="password"
                                       id="userPassword"
                                       name="password"
                                       autocomplete="current-password"
                                       class="form-control form-control-custom"
                                       placeholder="••••••••••••"
                                       required />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4 small">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="rememberMe" name="rememberMe" value="true" style="background-color: #333232; border-color: #444343;">
                                <label class="form-check-label text-secondary" for="rememberMe">Remember me</label>
                            </div>
                            <a href="#" class="text-link">Forgot password?</a>
                        </div>

                        <button type="submit" class="btn btn-signin w-100 py-2 fw-semibold mb-3">Sign in</button>
                    </form>

                    <div class="or-divider">or continue with</div>

                    <div class="d-flex flex-column gap-2">
                        <button class="btn btn-outline-custom w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-google text-danger"></i> Sign in with Google
                        </button>
                        <button class="btn btn-outline-custom w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-shield-lock"></i> Sign in with SSO
                        </button>
                    </div>

                    <div class="text-center mt-4 small text-secondary">
                        Don't have an account? @Html.ActionLink("Register", "Register", "Account")
                    </div>
                </div>
            </div>

        </div>
    </div>

</body>
</html>


